TICKETPILOT_GITHUB_PAT=ghp_...
TICKETPILOT_GITHUB_HANDLE=@YourBotHandle
TICKETPILOT_PROJECT_URL=https://github.com/users/you/projects/1
TICKETPILOT_REPO=owner/repo

# Optional overrides (defaults shown)
# TICKETPILOT_STATE_FILE=state.json
# TICKETPILOT_LOOKBACK_DAYS=30
# TICKETPILOT_INTERVAL=60

# Docker Compose: delegate image builds to Bake for better performance
COMPOSE_BAKE=true
